# PostgreSQL connection string for Prisma and the BITS application.
# Copy this file to `.env` and replace the placeholder values before running migrations.
#
# Local example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bits?schema=public"
#
# Railway example (set in the Railway service variables, not committed):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway?schema=public"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
