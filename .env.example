# PostgreSQL connection string for Prisma and the BITS application.
# Copy this file to `.env` and replace the placeholder values before running migrations.
#
# Local example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bits?schema=public"
#
# Railway example (set in the Railway service variables, not committed):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway?schema=public"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Clerk authentication (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk sign-in and sign-up page URLs (must match app routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# After sign-in/sign-up, Clerk redirects here by default unless overridden per flow
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Application base URL for local development
APP_BASE_URL=http://localhost:3000
