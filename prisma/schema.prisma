// BITS Version 1 — complete relational schema.
// See docs/bits-design-spec.md sections 8–10.
// Phase 2 payment tables (PaymentTransaction, PaymentRefund) are reserved for a future migration.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum RoleCode {
  ORG_ADMIN
  TREASURER
  DATA_ENTRY
  REPORT_VIEWER
  DONOR
}

enum OfferingBatchStatus {
  DRAFT
  ENTERED
  RECONCILED
  LOCKED
}

enum PaymentMethod {
  CASH
  CHECK
  CARD
  ACH
  STOCK_OR_NONCASH
  OTHER
}

enum StatementType {
  INDIVIDUAL
  HOUSEHOLD
}

enum StatementStatus {
  GENERATED
  PUBLISHED
  VOIDED
}

enum StatementAccessAction {
  GENERATED
  VIEWED
  DOWNLOADED
  EMAILED
  VOIDED
}

// ---------------------------------------------------------------------------
// Tenant and authentication projection
// ---------------------------------------------------------------------------

model Organization {
  id                  String   @id @default(uuid()) @db.Uuid
  clerkOrganizationId String?  @unique
  name                String
  slug                String   @unique
  ein                 String?
  mailingAddressLine1 String
  mailingAddressLine2 String?
  city                String
  state               String
  postalCode          String
  country             String   @default("US")
  contactEmail        String?
  contactPhone        String?
  logoStorageKey      String?
  statementFooterText String?
  timeZone            String   @default("America/New_York")
  locale              String   @default("en-US")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memberships            OrganizationMembership[]
  households             Household[]
  donors                 Donor[]
  householdMemberships   HouseholdMembership[]
  offeringTypes          OfferingType[]
  offeringBatches        OfferingBatch[]
  donations              Donation[]
  donationAllocations    DonationAllocation[]
  contributionStatements ContributionStatement[]
  statementAccessEvents  StatementAccessEvent[]
  auditEvents            AuditEvent[]

  @@map("organizations")
}

model UserAccount {
  id           String    @id @default(uuid()) @db.Uuid
  clerkUserId  String    @unique
  primaryEmail String
  displayName  String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSeenAt   DateTime?

  memberships            OrganizationMembership[]
  linkedDonors           Donor[]
  createdOfferingBatches OfferingBatch[]
  generatedStatements    ContributionStatement[]
  statementAccessEvents  StatementAccessEvent[]
  auditEvents            AuditEvent[]

  @@map("user_accounts")
}

model RoleType {
  id        String   @id @default(uuid()) @db.Uuid
  code      RoleCode @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships OrganizationMembership[]

  @@map("role_types")
}

model OrganizationMembership {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  userAccountId  String   @db.Uuid
  roleTypeId     String   @db.Uuid
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userAccount  UserAccount  @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  roleType     RoleType     @relation(fields: [roleTypeId], references: [id], onDelete: Restrict)

  @@unique([organizationId, userAccountId])
  @@index([organizationId])
  @@index([userAccountId])
  @@index([organizationId, active])
  @@map("organization_memberships")
}

// ---------------------------------------------------------------------------
// Donors and households
// ---------------------------------------------------------------------------

model Donor {
  id                           String    @id @default(uuid()) @db.Uuid
  organizationId               String    @db.Uuid
  userAccountId                String?   @db.Uuid
  firstName                    String
  lastName                     String
  email                        String?
  phone                        String?
  mailingAddressLine1          String?
  mailingAddressLine2          String?
  city                         String?
  state                        String?
  postalCode                   String?
  country                      String?
  preferredCommunicationMethod String?
  internalNotes                String?
  active                       Boolean   @default(true)
  deceased                     Boolean   @default(false)
  deceasedDate                 DateTime? @db.Date
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  organization                    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userAccount                     UserAccount?            @relation(fields: [userAccountId], references: [id], onDelete: SetNull)
  householdMemberships            HouseholdMembership[]
  donations                       Donation[]
  primaryContactForHouseholds     Household[]             @relation("HouseholdPrimaryContact")
  statementRecipientForHouseholds Household[]             @relation("HouseholdStatementRecipient")
  individualStatements            ContributionStatement[] @relation("StatementIndividualDonor")

  @@unique([organizationId, userAccountId])
  @@index([organizationId])
  @@index([organizationId, active])
  @@index([organizationId, lastName, firstName])
  @@map("donors")
}

model Household {
  id                            String   @id @default(uuid()) @db.Uuid
  organizationId                String   @db.Uuid
  displayName                   String
  mailingAddressLine1           String
  mailingAddressLine2           String?
  city                          String
  state                         String
  postalCode                    String
  country                       String   @default("US")
  primaryDonorId                String?  @db.Uuid
  preferredStatementRecipientId String?  @db.Uuid
  statementDeliveryMethod       String?
  active                        Boolean  @default(true)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  organization                Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  primaryDonor                Donor?                  @relation("HouseholdPrimaryContact", fields: [primaryDonorId], references: [id], onDelete: SetNull)
  preferredStatementRecipient Donor?                  @relation("HouseholdStatementRecipient", fields: [preferredStatementRecipientId], references: [id], onDelete: SetNull)
  memberships                 HouseholdMembership[]
  householdStatements         ContributionStatement[] @relation("StatementHousehold")

  @@index([organizationId])
  @@index([organizationId, active])
  @@map("households")
}

model HouseholdMembership {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String    @db.Uuid
  householdId       String    @db.Uuid
  donorId           String    @db.Uuid
  startDate         DateTime  @db.Date
  endDate           DateTime? @db.Date
  relationshipLabel String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  household    Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  donor        Donor        @relation(fields: [donorId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([householdId])
  @@index([donorId])
  @@index([donorId, endDate])
  @@index([householdId, endDate])
  @@map("household_memberships")
}

// ---------------------------------------------------------------------------
// Offering types, batches, donations
// ---------------------------------------------------------------------------

model OfferingType {
  id                   String   @id @default(uuid()) @db.Uuid
  organizationId       String   @db.Uuid
  name                 String
  description          String?
  code                 String?
  defaultTaxDeductible Boolean  @default(true)
  onlineGivingEnabled  Boolean  @default(false)
  displayOrder         Int      @default(0)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  allocations  DonationAllocation[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, active])
  @@map("offering_types")
}

model OfferingBatch {
  id                     String              @id @default(uuid()) @db.Uuid
  organizationId         String              @db.Uuid
  name                   String
  reference              String?
  offeringDate           DateTime            @db.Date
  serviceDescription     String?
  status                 OfferingBatchStatus @default(DRAFT)
  expectedTotal          Decimal?            @db.Decimal(12, 2)
  recordedTotal          Decimal             @default(0) @db.Decimal(12, 2)
  depositDate            DateTime?           @db.Date
  depositReference       String?
  notes                  String?
  createdByUserAccountId String              @db.Uuid
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    UserAccount  @relation(fields: [createdByUserAccountId], references: [id], onDelete: Restrict)
  donations    Donation[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, offeringDate])
  @@map("offering_batches")
}

model Donation {
  id                              String        @id @default(uuid()) @db.Uuid
  organizationId                  String        @db.Uuid
  donorId                         String?       @db.Uuid
  batchId                         String?       @db.Uuid
  offeringDate                    DateTime      @db.Date
  receivedDate                    DateTime      @db.Date
  paymentMethod                   PaymentMethod
  totalAmount                     Decimal       @db.Decimal(12, 2)
  checkNumber                     String?
  note                            String?
  anonymous                       Boolean       @default(false)
  isTaxDeductible                 Boolean       @default(true)
  deductibleAmount                Decimal       @db.Decimal(12, 2)
  goodsOrServicesProvided         Boolean       @default(false)
  goodsOrServicesDescription      String?
  goodsOrServicesEstimatedValue   Decimal?      @db.Decimal(12, 2)
  intangibleReligiousBenefitsOnly Boolean       @default(false)
  createdAt                       DateTime      @default(now())
  updatedAt                       DateTime      @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  donor        Donor?               @relation(fields: [donorId], references: [id], onDelete: Restrict)
  batch        OfferingBatch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  allocations  DonationAllocation[]

  @@index([organizationId])
  @@index([organizationId, offeringDate])
  @@index([organizationId, receivedDate])
  @@index([donorId])
  @@index([batchId])
  @@index([organizationId, paymentMethod])
  @@index([organizationId, anonymous])
  @@map("donations")
}

model DonationAllocation {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  donationId     String  @db.Uuid
  offeringTypeId String  @db.Uuid
  amount         Decimal @db.Decimal(12, 2)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  donation     Donation     @relation(fields: [donationId], references: [id], onDelete: Cascade)
  offeringType OfferingType @relation(fields: [offeringTypeId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([donationId])
  @@index([offeringTypeId])
  @@index([organizationId, offeringTypeId])
  @@map("donation_allocations")
}

// ---------------------------------------------------------------------------
// Statements and audit
// ---------------------------------------------------------------------------

model ContributionStatement {
  id                       String          @id @default(uuid()) @db.Uuid
  organizationId           String          @db.Uuid
  statementType            StatementType
  donorId                  String?         @db.Uuid
  householdId              String?         @db.Uuid
  periodStart              DateTime        @db.Date
  periodEnd                DateTime        @db.Date
  taxYear                  Int?
  deductibleTotal          Decimal         @db.Decimal(12, 2)
  statementIdentifier      String
  pdfStorageKey            String
  pdfChecksum              String?
  status                   StatementStatus @default(GENERATED)
  generatedByUserAccountId String          @db.Uuid
  generatedAt              DateTime        @default(now())
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  donor        Donor?                 @relation("StatementIndividualDonor", fields: [donorId], references: [id], onDelete: Restrict)
  household    Household?             @relation("StatementHousehold", fields: [householdId], references: [id], onDelete: Restrict)
  generatedBy  UserAccount            @relation(fields: [generatedByUserAccountId], references: [id], onDelete: Restrict)
  accessEvents StatementAccessEvent[]

  @@unique([organizationId, statementIdentifier])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, taxYear])
  @@index([donorId])
  @@index([householdId])
  @@map("contribution_statements")
}

model StatementAccessEvent {
  id             String                @id @default(uuid()) @db.Uuid
  organizationId String                @db.Uuid
  statementId    String                @db.Uuid
  userAccountId  String                @db.Uuid
  action         StatementAccessAction
  occurredAt     DateTime              @default(now())

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  statement    ContributionStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  userAccount  UserAccount           @relation(fields: [userAccountId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([statementId])
  @@index([userAccountId])
  @@index([organizationId, occurredAt])
  @@map("statement_access_events")
}

model AuditEvent {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @db.Uuid
  actorUserAccountId String?  @db.Uuid
  action             String
  entityType         String
  entityId           String   @db.Uuid
  changeMetadata     Json?
  occurredAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        UserAccount? @relation(fields: [actorUserAccountId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, occurredAt])
  @@index([organizationId, entityType, entityId])
  @@index([actorUserAccountId])
  @@map("audit_events")
}
